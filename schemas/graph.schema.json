{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.catalyst.dev/backtest/graph.schema.json",
  "title": "Catalyst Graph",
  "description": "A runnable Catalyst strategy graph: signal and action nodes connected by directed edges. This is the raw input accepted by the backtester before the graph compiler normalizes it.",
  "type": "object",
  "required": ["nodes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Producer schema identifier, e.g. catalyst.graph.definition.v1.",
      "default": "catalyst.graph.definition.v1"
    },
    "variables": {
      "type": "object",
      "description": "Named scalar values substitutable into node configs. Reference one as a \"$name\" string (e.g. \"amount\": \"$size\") or, in a signal reference, as { \"var\": \"name\" }. The compiler resolves them to concrete values; an undefined reference is a compile error and an unused variable warns.",
      "additionalProperties": { "type": ["string", "number", "boolean"] },
      "default": {}
    },
    "settings": {
      "type": "object",
      "description": "Reserved graph-level settings. Validated as an object but not yet honored by the backtester; request config and policy always take precedence, and any keys present are reported as ignored warnings.",
      "default": {}
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "default": [],
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "decimal": {
      "type": "string",
      "description": "A non-negative decimal carried as a string to avoid float precision loss, e.g. \"100\" or \"0.04\". The literal \"all\" is permitted for full-balance actions. A \"$name\" token references a graph variable, resolved by the compiler.",
      "pattern": "^(all|\\$[A-Za-z_][A-Za-z0-9_]*|[0-9]+(\\.[0-9]+)?)$"
    },
    "signedDecimal": {
      "type": "string",
      "description": "A signed decimal carried as a string, e.g. \"-0.05\". Used where negative thresholds are meaningful (funding rates, rate-of-change). A \"$name\" token references a graph variable.",
      "pattern": "^(\\$[A-Za-z_][A-Za-z0-9_]*|-?[0-9]+(\\.[0-9]+)?)$"
    },
    "amountOrPct": {
      "description": "An action amount: an absolute decimal (or \"all\"), or a percentage of a basis.",
      "oneOf": [
        { "$ref": "#/$defs/decimal" },
        {
          "type": "object",
          "required": ["basis", "value"],
          "additionalProperties": false,
          "properties": {
            "basis": { "type": "string", "enum": ["pct_balance", "pct_position", "pct_portfolio"] },
            "value": { "$ref": "#/$defs/decimal" }
          }
        }
      ]
    },
    "node": {
      "type": "object",
      "required": ["id", "kind", "subtype", "config"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["action", "signal"] },
        "subtype": {
          "type": "string",
          "enum": [
            "swap",
            "perp_order",
            "yield_deposit",
            "yield_withdraw",
            "price_threshold",
            "threshold",
            "all",
            "any",
            "not"
          ]
        },
        "config": { "type": "object" },
        "enabled": { "type": "boolean", "default": true }
      },
      "allOf": [
        {
          "if": { "properties": { "subtype": { "const": "swap" } } },
          "then": { "properties": { "config": { "$ref": "#/$defs/swapConfig" } } }
        },
        {
          "if": { "properties": { "subtype": { "const": "perp_order" } } },
          "then": { "properties": { "config": { "$ref": "#/$defs/perpOrderConfig" } } }
        },
        {
          "if": { "properties": { "subtype": { "const": "yield_deposit" } } },
          "then": { "properties": { "config": { "$ref": "#/$defs/yieldConfig" } } }
        },
        {
          "if": { "properties": { "subtype": { "const": "yield_withdraw" } } },
          "then": { "properties": { "config": { "$ref": "#/$defs/yieldConfig" } } }
        },
        {
          "if": { "properties": { "subtype": { "const": "price_threshold" } } },
          "then": { "properties": { "config": { "$ref": "#/$defs/priceThresholdConfig" } } }
        },
        {
          "if": { "properties": { "subtype": { "const": "threshold" } } },
          "then": { "properties": { "config": { "$ref": "#/$defs/thresholdConfig" } } }
        }
      ]
    },
    "edge": {
      "type": "object",
      "required": ["from", "to"],
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 }
      }
    },
    "swapConfig": {
      "type": "object",
      "required": ["from_asset", "to_asset", "amount", "chain"],
      "properties": {
        "from_asset": { "type": "string" },
        "to_asset": { "type": "string" },
        "amount": { "$ref": "#/$defs/amountOrPct" },
        "chain": { "type": "string", "description": "Venue/chain, e.g. base or hyperliquid." },
        "order_type": { "type": "string", "enum": ["market", "limit"], "default": "market" },
        "limit_price": { "$ref": "#/$defs/decimal", "description": "Worst acceptable price; required when order_type is limit." },
        "time_in_force": { "type": "string", "enum": ["gtc", "good_til_bars"], "default": "gtc" },
        "expire_after_bars": { "type": "integer", "minimum": 1, "description": "Bars until expiry when time_in_force is good_til_bars." }
      },
      "allOf": [
        {
          "if": { "properties": { "order_type": { "const": "limit" } }, "required": ["order_type"] },
          "then": { "required": ["limit_price"] }
        }
      ]
    },
    "perpOrderConfig": {
      "type": "object",
      "required": ["symbol", "side", "size_usd", "chain"],
      "properties": {
        "symbol": { "type": "string" },
        "side": { "type": "string", "enum": ["long", "short"] },
        "size_usd": { "$ref": "#/$defs/amountOrPct" },
        "leverage": { "$ref": "#/$defs/decimal" },
        "chain": { "type": "string" },
        "order_type": { "type": "string", "enum": ["market", "limit"], "default": "market" },
        "reduce_only": { "type": "boolean", "default": false },
        "limit_price": { "$ref": "#/$defs/decimal", "description": "Worst acceptable mark price; required when order_type is limit." },
        "time_in_force": { "type": "string", "enum": ["gtc", "good_til_bars"], "default": "gtc" },
        "expire_after_bars": { "type": "integer", "minimum": 1, "description": "Bars until expiry when time_in_force is good_til_bars." }
      },
      "allOf": [
        {
          "if": { "properties": { "order_type": { "const": "limit" } }, "required": ["order_type"] },
          "then": { "required": ["limit_price"] }
        }
      ]
    },
    "yieldConfig": {
      "type": "object",
      "required": ["chain", "protocol", "asset", "amount"],
      "properties": {
        "chain": { "type": "string" },
        "protocol": { "type": "string", "description": "Yield protocol, e.g. aave." },
        "pool": { "type": "string" },
        "asset": { "type": "string" },
        "amount": { "$ref": "#/$defs/amountOrPct" }
      }
    },
    "priceThresholdConfig": {
      "type": "object",
      "required": ["symbol", "operator", "threshold"],
      "properties": {
        "symbol": { "type": "string" },
        "operator": { "type": "string", "enum": ["<", "<=", ">", ">=", "==", "!="] },
        "threshold": { "$ref": "#/$defs/decimal" }
      }
    },
    "operator": { "type": "string", "enum": ["<", "<=", ">", ">=", "==", "!="] },
    "source": {
      "type": "object",
      "description": "The scalar a signal observes. Each kind maps to one market-data series.",
      "required": ["kind"],
      "oneOf": [
        {
          "properties": {
            "kind": { "const": "price" },
            "symbol": { "type": "string" },
            "venue": { "type": "string" }
          },
          "required": ["kind", "symbol"],
          "additionalProperties": false
        },
        {
          "properties": {
            "kind": { "const": "funding" },
            "venue": { "type": "string" },
            "symbol": { "type": "string" }
          },
          "required": ["kind", "venue", "symbol"],
          "additionalProperties": false
        },
        {
          "properties": {
            "kind": { "const": "yield" },
            "protocol": { "type": "string" },
            "asset": { "type": "string" },
            "chain": { "type": "string" },
            "pool": { "type": "string" }
          },
          "required": ["kind", "protocol", "asset", "chain"],
          "additionalProperties": false
        },
        {
          "properties": {
            "kind": { "const": "gas" },
            "chain": { "type": "string" }
          },
          "required": ["kind", "chain"],
          "additionalProperties": false
        },
        {
          "properties": {
            "kind": { "const": "derived" },
            "of": { "$ref": "#/$defs/source" },
            "transform": { "type": "string", "enum": ["sma", "ema", "rolling_high", "rolling_low", "roc"] },
            "window": { "type": "integer", "minimum": 1 }
          },
          "required": ["kind", "of", "transform", "window"],
          "additionalProperties": false
        }
      ]
    },
    "reference": {
      "description": "The right-hand side of a signal comparison: a constant, another source, or a graph variable.",
      "oneOf": [
        {
          "type": "object",
          "required": ["const"],
          "additionalProperties": false,
          "properties": { "const": { "$ref": "#/$defs/signedDecimal" } }
        },
        {
          "type": "object",
          "required": ["source"],
          "additionalProperties": false,
          "properties": { "source": { "$ref": "#/$defs/source" } }
        },
        {
          "type": "object",
          "required": ["var"],
          "additionalProperties": false,
          "properties": { "var": { "type": "string" } }
        }
      ]
    },
    "thresholdConfig": {
      "type": "object",
      "required": ["source", "operator", "reference"],
      "additionalProperties": false,
      "properties": {
        "source": { "$ref": "#/$defs/source" },
        "operator": { "$ref": "#/$defs/operator" },
        "reference": { "$ref": "#/$defs/reference" }
      }
    }
  }
}
