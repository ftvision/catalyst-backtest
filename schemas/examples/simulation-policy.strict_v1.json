{
  "schema_version": "catalyst.backtest.policy.v1",
  "profile": "strict_v1",
  "balance": { "insufficient_balance": "reject" },
  "fills": {
    "partial_fills": "none",
    "price_selection": "next_open",
    "slippage": { "model": "fixed_bps", "bps": "10" },
    "fees": { "model": "fixed_bps", "bps": "5" }
  },
  "gas": {
    "model": "historical_fee_history",
    "fallback": { "model": "fixed_usd", "amount": "0.25" }
  },
  "signals": { "trigger": "crossing", "repeat": "on_each_signal_fire", "cooldown": null },
  "ordering": { "same_tick": "topological_order" },
  "data": { "missing_required": "fail", "missing_optional": "warn" },
  "perps": { "liquidation_check": "every_tick", "funding": "historical", "reduce_only_validation": "strict" },
  "yield": { "accrual": "simple_apr" }
}
