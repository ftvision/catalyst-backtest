# Copy to .env.r2 (git-ignored) and fill in your Cloudflare R2 details.
# I source this at runtime to upload the store and set Fly secrets — the values
# never appear in the chat. Rotate the token whenever you like; nothing here is
# committed.

# Cloudflare R2 S3-compatible credentials (R2 dashboard -> Manage R2 API Tokens)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bucket name and account endpoint (R2 dashboard)
R2_BUCKET=catalyst-market-data
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
