      "kind": "action",
      "subtype": "swap",
      "config": {
        "from_asset": "USDC",
        "to_asset": "ETH",
        "amount": { "basis": "pct_portfolio", "value": "50" },
        "chain": "base"
      },
      "enabled": true
    },
    {
      "id": "new-20-bar-low",
      "kind": "signal",
